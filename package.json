{
  "name": "team-budget-tracker",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "frontend": "cd frontend && npm start",
    "frontend:tunnel": "cd frontend && npm run tunnel",
    "server": "cd server && npm run dev",
    "dev": "concurrently \"npm run server\" \"npm run frontend\"",
    "install:all": "cd frontend && npm install && cd ../server && npm install",
    "vercel-build": "cd server && npm install && npm run build"
  },
  "dependencies": {
    "axios": "^1.15.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-validator": "^7.2.1",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^7.2.0",
    "mongoose": "^8.9.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.0",
    "concurrently": "^9.1.0",
    "typescript": "~5.7.0"
  }
}
