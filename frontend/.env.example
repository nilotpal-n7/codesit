# ─── Frontend Environment Variables ───────────────────────────────────────────
# Copy this to .env and fill in your values.
# Expo requires the EXPO_PUBLIC_ prefix for client-accessible env vars.

# Your computer's local IP address (for Expo Go on physical device)
# Find it with:
#   Linux:   hostname -I | awk '{print $1}'
#   macOS:   ipconfig getifaddr en0
#   Windows: ipconfig | findstr IPv4
EXPO_PUBLIC_API_IP=192.168.x.x

# Server port (must match server/.env PORT)
EXPO_PUBLIC_API_PORT=5000
